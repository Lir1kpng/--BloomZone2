/* style.css — современный, адаптивный, Fogma-стиль */

/* Общие сбросы и переменные */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
}

:root {
  --primary: #e05a7a;      /* нежно-розовый акцент */
  --primary-dark: #b43e5c;
  --bg-light: #fdf8f6;
  --card-bg: #ffffff;
  --text-dark: #2d1e2a;
  --text-soft: #5a4a52;
  --shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
  --radius: 28px;
  --transition: 0.25s ease;
}

body {
  background-color: var(--bg-light);
  color: var(--text-dark);
  line-height: 1.5;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Шапка */
.header {
  background: rgba(255, 248, 245, 0.85);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid rgba(224, 90, 122, 0.08);
}

.header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  flex-wrap: wrap;
}

.header__logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: 1.6rem;
  letter-spacing: -0.5px;
}

.logo-icon {
  font-size: 2rem;
}
.logo-text {
  background: linear-gradient(135deg, #e05a7a, #c44e6b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Навигация */
.header__nav {
  display: flex;
}
.nav-list {
  display: flex;
  list-style: none;
  gap: 2rem;
}
.nav-link {
  text-decoration: none;
  color: var(--text-soft);
  font-weight: 500;
  font-size: 1rem;
  transition: color var(--transition);
  position: relative;
}
.nav-link:hover,
.nav-link.active {
  color: var(--primary);
}
.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: -6px;
  left: 0;
  width: 100%;
  height: 3px;
  background: var(--primary);
  border-radius: 10px;
}

/* Действия шапки */
.header__actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.cart-btn {
  background: none;
  border: none;
  font-size: 1.5rem;
  cursor: pointer;
  position: relative;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  border-radius: 40px;
  background: rgba(224, 90, 122, 0.08);
  transition: background var(--transition);
}
.cart-btn:hover {
  background: rgba(224, 90, 122, 0.16);
}
.cart-badge {
  background: var(--primary);
  color: white;
  border-radius: 30px;
  padding: 0 8px;
  font-size: 0.75rem;
  font-weight: 600;
  min-width: 22px;
  text-align: center;
  line-height: 22px;
}

.menu-toggle {
  display: none;
  background: none;
  border: none;
  width: 30px;
  height: 30px;
  flex-direction: column;
  justify-content: space-around;
  padding: 4px;
  cursor: pointer;
}
.menu-icon {
  display: block;
  width: 100%;
  height: 3px;
  background: var(--text-dark);
  border-radius: 10px;
  transition: 0.2s;
  position: relative;
}
.menu-icon::before,
.menu-icon::after {
  content: '';
  position: absolute;
  width: 100%;
  height: 3px;
  background: var(--text-dark);
  border-radius: 10px;
  transition: 0.2s;
}
.menu-icon::before { top: -8px; }
.menu-icon::after { bottom: -8px; }

/* Hero */
.hero {
  padding: 60px 0 40px;
  background: linear-gradient(145deg, #fceae8 0%, #fdf5f2 100%);
  border-radius: 0 0 60px 60px;
  margin-bottom: 20px;
}
.hero__content {
  text-align: center;
  padding: 20px 0;
}
.hero__title {
  font-size: 3rem;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 16px;
}
.hero__subtitle {
  font-size: 1.2rem;
  color: var(--text-soft);
  margin-bottom: 28px;
}
.btn {
  display: inline-block;
  background: white;
  border: none;
  padding: 14px 34px;
  border-radius: 60px;
  font-weight: 600;
  font-size: 1rem;
  text-decoration: none;
  color: var(--text-dark);
  box-shadow: var(--shadow);
  transition: all var(--transition);
  cursor: pointer;
}
.btn-primary {
  background: var(--primary);
  color: white;
  box-shadow: 0 8px 24px rgba(224, 90, 122, 0.3);
}
.btn-primary:hover {
  background: var(--primary-dark);
  transform: translateY(-3px);
  box-shadow: 0 12px 28px rgba(224, 90, 122, 0.4);
}

/* Каталог */
.section-title {
  font-size: 2.2rem;
  font-weight: 600;
  margin: 40px 0 28px;
  letter-spacing: -0.3px;
}
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
  gap: 30px;
  margin-bottom: 40px;
}

/* Карточка товара */
.product-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 20px 16px 20px;
  box-shadow: var(--shadow);
  transition: transform 0.2s, box-shadow 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border: 1px solid rgba(224, 90, 122, 0.04);
}
.product-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 35px rgba(0,0,0,0.06);
}
.product-card__image {
  font-size: 4.5rem;
  line-height: 1;
  margin-bottom: 8px;
}
.product-card__name {
  font-weight: 600;
  font-size: 1.1rem;
  margin-bottom: 4px;
}
.product-card__price {
  color: var(--primary);
  font-weight: 600;
  font-size: 1.2rem;
  margin: 8px 0 12px;
}
.add-to-cart {
  background: rgba(224, 90, 122, 0.06);
  border: 1px solid rgba(224, 90, 122, 0.1);
  padding: 10px 20px;
  border-radius: 60px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  width: 100%;
  color: var(--primary-dark);
}
.add-to-cart:hover {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

/* Корзина overlay (Fogma стиль) */
.cart-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.2);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 20px;
}
.cart-overlay.open {
  display: flex;
}
.cart-modal {
  background: white;
  max-width: 450px;
  width: 100%;
  border-radius: 40px;
  padding: 24px 24px 28px;
  box-shadow: 0 40px 80px rgba(0,0,0,0.12);
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(40px); opacity: 0.5; }
  to { transform: translateY(0); opacity: 1; }
}
.cart-modal__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18px;
}
.cart-modal__header h3 {
  font-size: 1.6rem;
  font-weight: 600;
}
.cart-modal__close {
  background: none;
  border: none;
  font-size: 1.8rem;
  cursor: pointer;
  color: #aaa;
  transition: color 0.2s;
  line-height: 1;
}
.cart-modal__close:hover {
  color: var(--text-dark);
}
.cart-modal__body {
  min-height: 80px;
  margin-bottom: 20px;
}
.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0e8e5;
}
.cart-item__info {
  display: flex;
  align-items: center;
  gap: 12px;
}
.cart-item__emoji {
  font-size: 2rem;
}
.cart-item__name {
  font-weight: 500;
}
.cart-item__price {
  color: var(--primary);
  font-weight: 600;
}
.cart-item__remove {
  background: none;
  border: none;
  color: #b0a0a0;
  font-size: 1.2rem;
  cursor: pointer;
}
.cart-empty {
  color: var(--text-soft);
  text-align: center;
  padding: 20px 0;
}
.cart-modal__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #f0e8e5;
  padding-top: 18px;
}
.cart-total {
  font-size: 1.2rem;
}
.btn-checkout {
  background: var(--primary);
  color: white;
  border: none;
  padding: 12px 28px;
  border-radius: 60px;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-checkout:hover {
  background: var(--primary-dark);
}

/* Футер */
.footer {
  margin-top: auto;
  background: white;
  border-top: 1px solid rgba(224, 90, 122, 0.04);
  padding: 28px 0;
}
.footer__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  color: var(--text-soft);
}
.footer__note {
  font-size: 0.9rem;
}

/* АДАПТИВ (мобильные) */
@media (max-width: 768px) {
  .header__nav {
    display: none;
    width: 100%;
    order: 3;
    padding-top: 12px;
  }
  .header__nav.open {
    display: block;
  }
  .nav-list {
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    background: rgba(255,248,245,0.9);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 18px 0;
    border-radius: 40px;
  }
  .menu-toggle {
    display: flex;
  }
  .hero__title {
    font-size: 2.4rem;
  }
  .product-grid {
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }
  .cart-modal {
    max-width: 95%;
    padding: 20px;
  }
  .footer__inner {
    flex-direction: column;
    text-align: center;
  }
}
@media (max-width: 480px) {
  .header__logo {
    font-size: 1.3rem;
  }
  .hero__title {
    font-size: 2rem;
  }
  .btn {
    padding: 12px 28px;
  }
  .product-grid {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .product-card {
    padding: 14px 10px;
  }
  .product-card__image {
    font-size: 3.4rem;
  }
}